# Vercel Production + Preview environment variables
# Add these in Vercel Dashboard → Project → Settings → Environment Variables

# Convex (required on Vercel — NOT in git)
# Create with: bunx convex deployment token create vercel-prod --prod
CONVEX_DEPLOY_KEY=prod:your_deploy_key_from_convex_dashboard
VITE_CONVEX_URL=https://your-prod-deployment.convex.cloud

# NEVER add these to Vercel (local dev only — from `convex dev`):
# CONVEX_DEPLOYMENT=dev:your-dev-name
# CONVEX_URL=...

# Clerk auth (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Groq AI (required for extraction)
VITE_GROQ_API_KEY=gsk_...
VITE_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VITE_GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Optional — mock extract without calling Groq (demo only)
# VITE_GROQ_MOCK_EXTRACT=true
