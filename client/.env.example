# Groq AI — Convex URL lives in .env.local (managed by `convex dev`)
VITE_GROQ_API_KEY=your_key_here
VITE_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VITE_GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Clerk auth (https://dashboard.clerk.com)
# Issuer (Convex env only): https://your-app.clerk.accounts.dev
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional — mock extract without calling Groq
# VITE_GROQ_MOCK_EXTRACT=true

# Vercel only (Convex Production Deploy Key)
# CONVEX_DEPLOY_KEY=
