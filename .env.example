# Environment files live under client/ — not in this repo root.
#
# client/.env
#   VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
#
# client/.env.local  (created/updated by `bunx convex dev` in client/)
#   VITE_CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud
#   VITE_GROQ_API_KEY=...
#
# Convex dashboard env (not in Vite):
#   CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
#
# From repo root:
#   bun run dev          → Vite only (client/)
#   cd client && bun run start   → Convex dev + Vite together
